---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Vision Web | Páginas Web que Conectan">
  <!-- ===================== HERO SECTION ===================== -->
  <section class="relative min-h-[calc(100vh-80px)] flex items-center justify-center overflow-hidden">
    <!-- Animated Gradient Orbs -->
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>

    <!-- Floating Particles -->
    <div id="particles" class="absolute inset-0 pointer-events-none"></div>

    <!-- Grid Pattern Overlay -->
    <div class="absolute inset-0 grid-pattern opacity-50"></div>

    <!-- Content -->
    <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
      <!-- Large VW Logo -->
      <div class="hero-logo mb-8 logo-pulse cursor-pointer">
        <svg width="180" height="135" viewBox="0 0 160 120" fill="none" xmlns="http://www.w3.org/2000/svg" class="mx-auto drop-shadow-[0_0_35px_rgba(37,99,235,0.4)]">
          <!-- V (currentColor) -->
          <path d="M 10 15 L 25 15 L 48 80 L 71 15 L 86 15 L 55 105 L 41 105 Z" fill="currentColor" />
          <!-- W (Blue #2563EB) -->
          <path d="M 56 15 L 71 15 L 83 60 L 95 15 L 110 15 L 122 60 L 134 15 L 149 15 L 130 105 L 115 105 L 100 50 L 85 105 L 70 105 Z" fill="#2563EB" />
        </svg>
      </div>

      <!-- Title -->
      <h1 class="hero-title text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-extrabold tracking-tight mb-4">
        VISION <span class="text-[#2563EB]">WEB</span>
      </h1>

      <!-- Tagline -->
      <p class="hero-subtitle text-xl sm:text-2xl md:text-3xl font-light text-white/80 mb-6 tracking-wide">
        Páginas web que conectan
      </p>

      <!-- Subtitle -->
      <p class="hero-desc text-base sm:text-lg text-white/50 max-w-2xl mx-auto mb-10 leading-relaxed">
        Creamos páginas web que conectan tu negocio con más clientes.
        <span class="text-white/70 font-medium">Diseño</span> <span class="text-white/30">|</span>
        <span class="text-white/70 font-medium">Desarrollo</span> <span class="text-white/30">|</span>
        <span class="text-white/70 font-medium">Estrategia</span>
      </p>

      <!-- CTAs -->
      <div class="hero-cta flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/contacto" class="btn-shine bg-[#2563EB] hover:bg-blue-700 text-white font-semibold px-8 py-4 rounded-xl transition-all duration-300 hover:shadow-2xl hover:shadow-blue-500/30 hover:-translate-y-0.5 text-base w-full sm:w-auto text-center">
          Solicitar Cotización
        </a>
        <a href="/proyectos" class="border border-white/20 hover:border-white/40 text-white font-semibold px-8 py-4 rounded-xl transition-all duration-300 hover:bg-white/5 text-base w-full sm:w-auto text-center">
          Ver Proyectos
        </a>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <div class="w-6 h-10 rounded-full border-2 border-white/20 flex items-start justify-center p-1.5">
        <div class="w-1.5 h-3 bg-white/40 rounded-full animate-pulse"></div>
      </div>
    </div>
  </section>

  <!-- ===================== SERVICES PREVIEW ===================== -->
  <section class="relative py-24 md:py-32 bg-[#1F1F1F]">
    <div class="absolute inset-0 grid-pattern opacity-30"></div>
    <div class="relative z-10 mx-auto max-w-6xl px-6">
      <!-- Section Header -->
      <div class="text-center mb-16 reveal">
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-6">
          Soluciones web que <span class="text-[#2563EB]">impulsan</span> tu negocio
        </h2>
        <p class="text-white/50 max-w-xl mx-auto text-base md:text-lg">
          Cada proyecto es único. Combinamos diseño, tecnología y estrategia para crear experiencias digitales que generan resultados.
        </p>
      </div>

      <!-- Service Cards Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Card 1 -->
        <div class="service-card bg-[#0D0D0D] rounded-2xl p-7 border border-white/5 reveal">
          <div class="w-14 h-14 rounded-xl bg-[#2563EB]/10 flex items-center justify-center mb-6">
            <i data-lucide="palette" class="w-7 h-7 text-[#2563EB]"></i>
          </div>
          <h3 class="text-lg font-bold mb-3">Diseño Web Profesional</h3>
          <p class="text-white/50 text-sm leading-relaxed">Páginas web modernas, responsivas y visualmente impactantes que reflejan la identidad de tu marca.</p>
        </div>

        <!-- Card 2 -->
        <div class="service-card bg-[#0D0D0D] rounded-2xl p-7 border border-white/5 reveal" style="transition-delay: 0.1s;">
          <div class="w-14 h-14 rounded-xl bg-[#2563EB]/10 flex items-center justify-center mb-6">
            <i data-lucide="code-2" class="w-7 h-7 text-[#2563EB]"></i>
          </div>
          <h3 class="text-lg font-bold mb-3">Desarrollo a Medida</h3>
          <p class="text-white/50 text-sm leading-relaxed">Soluciones personalizadas con tecnología de vanguardia. Funcionalidades pensadas para tu negocio.</p>
        </div>

        <!-- Card 3 -->
        <div class="service-card bg-[#0D0D0D] rounded-2xl p-7 border border-white/5 reveal" style="transition-delay: 0.2s;">
          <div class="w-14 h-14 rounded-xl bg-[#2563EB]/10 flex items-center justify-center mb-6">
            <i data-lucide="target" class="w-7 h-7 text-[#2563EB]"></i>
          </div>
          <h3 class="text-lg font-bold mb-3">Estrategia Digital</h3>
          <p class="text-white/50 text-sm leading-relaxed">SEO, analítica y estrategia digital para que tu página no solo exista, sino que trabaje por ti.</p>
        </div>

        <!-- Card 4 -->
        <div class="service-card bg-[#0D0D0D] rounded-2xl p-7 border border-white/5 reveal" style="transition-delay: 0.3s;">
          <div class="w-14 h-14 rounded-xl bg-[#2563EB]/10 flex items-center justify-center mb-6">
            <i data-lucide="shield-check" class="w-7 h-7 text-[#2563EB]"></i>
          </div>
          <h3 class="text-lg font-bold mb-3">Soporte y Mantenimiento</h3>
          <p class="text-white/50 text-sm leading-relaxed">Acompañamiento continuo, actualizaciones y soporte técnico para que tu web siempre esté al día.</p>
        </div>
      </div>

      <!-- Link to all services -->
      <div class="text-center mt-12 reveal">
        <a href="/servicios" class="inline-flex items-center gap-2 text-[#2563EB] hover:text-blue-400 font-semibold transition-colors group">
          Ver todos los servicios
          <i data-lucide="arrow-right" class="w-4 h-4 transition-transform group-hover:translate-x-1"></i>
        </a>
      </div>
    </div>
  </section>

  <!-- ===================== PROCESS SECTION ===================== -->
  <section class="relative py-24 md:py-32 bg-[#0D0D0D]">
    <div class="absolute inset-0 grid-pattern opacity-30"></div>
    <div class="relative z-10 mx-auto max-w-6xl px-6">
      <!-- Section Header -->
      <div class="text-center mb-20 reveal">
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold">
          Nuestro <span class="text-[#2563EB]">Proceso</span>
        </h2>
      </div>

      <!-- Timeline -->
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8 md:gap-4 relative reveal">
        <!-- Connecting Line (desktop) -->
        <div class="hidden md:block absolute top-[52px] left-[12.5%] right-[12.5%] h-[2px] bg-gradient-to-r from-[#2563EB]/20 via-[#2563EB]/50 to-[#2563EB]/20"></div>

        <!-- Connecting Line (mobile) -->
        <div class="block md:hidden absolute top-[36px] bottom-[36px] left-[50%] -translate-x-[50%] w-[2px] bg-gradient-to-b from-[#2563EB]/10 via-[#2563EB]/40 to-[#2563EB]/10"></div>

        <!-- Step 1 -->
        <div class="process-step text-center relative">
          <div class="flex flex-col items-center">
            <div class="step-number timeline-dot w-[72px] h-[72px] rounded-full bg-[#1F1F1F] border-2 border-[#2563EB]/30 flex items-center justify-center mb-6 z-10">
              <span class="text-[#2563EB] text-2xl font-bold">01</span>
            </div>
            <h3 class="text-xl font-bold mb-3">Estrategia</h3>
            <p class="text-white/50 text-sm leading-relaxed max-w-[200px] mx-auto">Analizamos tu negocio, tu audiencia y tus objetivos para crear un plan sólido.</p>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="process-step text-center relative">
          <div class="flex flex-col items-center">
            <div class="step-number timeline-dot w-[72px] h-[72px] rounded-full bg-[#1F1F1F] border-2 border-[#2563EB]/30 flex items-center justify-center mb-6 z-10">
              <span class="text-[#2563EB] text-2xl font-bold">02</span>
            </div>
            <h3 class="text-xl font-bold mb-3">Diseño</h3>
            <p class="text-white/50 text-sm leading-relaxed max-w-[200px] mx-auto">Creamos mockups y prototipos con un diseño visual que conecta con tu marca.</p>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="process-step text-center relative">
          <div class="flex flex-col items-center">
            <div class="step-number timeline-dot w-[72px] h-[72px] rounded-full bg-[#1F1F1F] border-2 border-[#2563EB]/30 flex items-center justify-center mb-6 z-10">
              <span class="text-[#2563EB] text-2xl font-bold">03</span>
            </div>
            <h3 class="text-xl font-bold mb-3">Desarrollo</h3>
            <p class="text-white/50 text-sm leading-relaxed max-w-[200px] mx-auto">Construimos tu web con código limpio, rápido y optimizado para buscadores.</p>
          </div>
        </div>

        <!-- Step 4 -->
        <div class="process-step text-center relative">
          <div class="flex flex-col items-center">
            <div class="step-number timeline-dot w-[72px] h-[72px] rounded-full bg-[#1F1F1F] border-2 border-[#2563EB]/30 flex items-center justify-center mb-6 z-10">
              <span class="text-[#2563EB] text-2xl font-bold">04</span>
            </div>
            <h3 class="text-xl font-bold mb-3">Lanzamiento</h3>
            <p class="text-white/50 text-sm leading-relaxed max-w-[200px] mx-auto">Publicamos tu web, la optimizamos y te acompañamos en el camino al éxito.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== VALUE PROPOSITION ===================== -->
  <section class="relative py-24 md:py-32 bg-[#1F1F1F]">
    <div class="absolute inset-0 grid-pattern opacity-30"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-[#2563EB]/5 rounded-full blur-3xl pointer-events-none"></div>

    <div class="relative z-10 mx-auto max-w-6xl px-6">
      <!-- Section Header -->
      <div class="text-center mb-16 reveal">
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-6">
          Tu página web es tu <span class="text-[#2563EB]">mejor vendedor</span>
        </h2>
        <p class="text-white/50 max-w-xl mx-auto text-base md:text-lg">
          Una página web profesional no es un gasto, es la inversión más inteligente para tu negocio.
        </p>
      </div>

      <!-- Value Cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
        <!-- Value 1 -->
        <div class="value-card bg-[#0D0D0D]/60 backdrop-blur-sm rounded-2xl p-8 border border-white/5 text-center reveal">
          <div class="w-16 h-16 rounded-2xl bg-[#2563EB]/10 flex items-center justify-center mx-auto mb-6">
            <i data-lucide="clock" class="w-8 h-8 text-[#2563EB]"></i>
          </div>
          <h3 class="text-xl font-bold mb-4">Trabaja por ti 24/7</h3>
          <p class="text-white/50 text-sm leading-relaxed">Tu web nunca duerme. Atrae clientes, muestra tus servicios y genera confianza las 24 horas del día, los 7 días de la semana.</p>
        </div>

        <!-- Value 2 -->
        <div class="value-card bg-[#0D0D0D]/60 backdrop-blur-sm rounded-2xl p-8 border border-white/5 text-center reveal" style="transition-delay: 0.1s;">
          <div class="w-16 h-16 rounded-2xl bg-[#2563EB]/10 flex items-center justify-center mx-auto mb-6">
            <i data-lucide="bar-chart-3" class="w-8 h-8 text-[#2563EB]"></i>
          </div>
          <h3 class="text-xl font-bold mb-4">Diseño estratégico pensado en resultados</h3>
          <p class="text-white/50 text-sm leading-relaxed">No solo hacemos páginas bonitas. Cada elemento está diseñado para guiar a tus visitantes hacia la acción.</p>
        </div>

        <!-- Value 3 -->
        <div class="value-card bg-[#0D0D0D]/60 backdrop-blur-sm rounded-2xl p-8 border border-white/5 text-center reveal" style="transition-delay: 0.2s;">
          <div class="w-16 h-16 rounded-2xl bg-[#2563EB]/10 flex items-center justify-center mx-auto mb-6">
            <i data-lucide="globe" class="w-8 h-8 text-[#2563EB]"></i>
          </div>
          <h3 class="text-xl font-bold mb-4">Conecta tu negocio con el mundo</h3>
          <p class="text-white/50 text-sm leading-relaxed">Llega a más personas, rompe barreras geográficas y posiciona tu marca en el mundo digital.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== CTA SECTION ===================== -->
  <section class="relative py-24 md:py-32 bg-[#0D0D0D] overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#2563EB]/30 to-transparent"></div>
      <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#2563EB]/30 to-transparent"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[400px] bg-[#2563EB]/5 rounded-full blur-3xl"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-4xl px-6 text-center reveal">
      <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
        ¿Listo para transformar tu <span class="text-[#2563EB]">presencia digital</span>?
      </h2>

      <p class="text-white/50 text-base md:text-lg max-w-2xl mx-auto mb-10 leading-relaxed">
        Conversemos sobre tu proyecto. Te ayudamos a crear una página web que realmente conecte con tus clientes y haga crecer tu negocio.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/contacto" class="btn-shine bg-[#2563EB] hover:bg-blue-700 text-white font-semibold px-10 py-4 rounded-xl transition-all duration-300 hover:shadow-2xl hover:shadow-blue-500/30 hover:-translate-y-0.5 text-base inline-flex items-center gap-2 w-full sm:w-auto justify-center">
          <i data-lucide="send" class="w-5 h-5"></i>
          Contáctanos Ahora
        </a>
        <a href="https://wa.me/573052311490" target="_blank" class="border border-white/20 hover:border-green-500/50 text-white font-semibold px-10 py-4 rounded-xl transition-all duration-300 hover:bg-green-500/10 text-base inline-flex items-center gap-2 w-full sm:w-auto justify-center">
          <i data-lucide="message-circle" class="w-5 h-5 text-green-400"></i>
          WhatsApp
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero reveal animations */
  .hero-title {
    animation: heroReveal 1s ease-out 0.3s both;
  }
  .hero-subtitle {
    animation: heroReveal 1s ease-out 0.6s both;
  }
  .hero-desc {
    animation: heroReveal 1s ease-out 0.9s both;
  }
  .hero-cta {
    animation: heroReveal 1s ease-out 1.2s both;
  }
  .hero-logo {
    animation: logoReveal 1.2s ease-out 0s both;
  }

  @keyframes heroReveal {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes logoReveal {
    from {
      opacity: 0;
      transform: scale(0.5) rotate(-10deg);
    }
    to {
      opacity: 1;
      transform: scale(1) rotate(0deg);
    }
  }

  /* Service card hover */
  .service-card {
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }
  .service-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(135deg, transparent 40%, #2563EB 100%);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .service-card:hover::before {
    opacity: 1;
  }
  .service-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 60px -15px rgba(37, 99, 235, 0.25);
  }

  /* Value card hover */
  .value-card {
    transition: all 0.3s ease;
  }
  .value-card:hover {
    transform: translateY(-4px);
    background: rgba(37, 99, 235, 0.08);
  }


  .timeline-dot {
    position: relative;
  }
  .timeline-dot::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 2px solid #2563EB;
    opacity: 0;
    animation: dotPulse 2.5s ease-out infinite;
  }
  @keyframes dotPulse {
    0% {
      transform: scale(1);
      opacity: 0.6;
    }
    100% {
      transform: scale(1.8);
      opacity: 0;
    }
  }
</style>

<script is:inline>
  // Simple particle system
  function initParticles() {
    const container = document.getElementById('particles');
    if (!container) return;
    container.innerHTML = '';
    const count = 30;
    for (let i = 0; i < count; i++) {
      const p = document.createElement('div');
      p.className = 'absolute w-[3px] h-[3px] bg-blue-500/30 rounded-full pointer-events-none';
      p.style.left = `${Math.random() * 100}%`;
      p.style.bottom = `-10px`;
      p.style.opacity = Math.random().toString();
      
      const duration = 5 + Math.random() * 8;
      const delay = Math.random() * 5;
      p.style.animation = `particleFloat ${duration}s linear ${delay}s infinite`;
      container.appendChild(p);
    }
  }

  // Keyframes for particle float dynamically added if not exist
  if (!document.getElementById('particle-style')) {
    const style = document.createElement('style');
    style.id = 'particle-style';
    style.innerHTML = `
      @keyframes particleFloat {
        0% { transform: translateY(0) scale(0); opacity: 0; }
        10% { opacity: 0.5; transform: scale(1); }
        90% { opacity: 0.2; }
        100% { transform: translateY(-100vh) scale(0.5); opacity: 0; }
      }
    `;
    document.head.appendChild(style);
  }

  // Initialize on load and on page navigation
  initParticles();
  document.addEventListener('astro:page-load', initParticles);

  // Scroll reveal setup
  function setupScrollReveal() {
    const reveals = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
    
    reveals.forEach(el => observer.observe(el));
  }
  setupScrollReveal();
  document.addEventListener('astro:page-load', setupScrollReveal);
</script>
