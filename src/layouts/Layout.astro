---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Vision Web - Creamos páginas web profesionales que conectan tu negocio con más clientes." } = Astro.props;
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    
    <!-- Theme Initialization script to avoid Flash of Dark Mode (FOUC) -->
    <script is:inline>
      (function() {
        const savedTheme = localStorage.getItem('theme');
        const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (savedTheme === 'light' || (!savedTheme && !systemPrefersDark)) {
          document.documentElement.classList.add('light');
        } else {
          document.documentElement.classList.remove('light');
        }
      })();
    </script>
    <ClientRouter />
    <style is:global>
      * {
        font-family: 'Montserrat', sans-serif;
      }

      /* Scrollbar */
      ::-webkit-scrollbar {
        width: 8px;
      }
      ::-webkit-scrollbar-track {
        background: #0D0D0D;
      }
      ::-webkit-scrollbar-thumb {
        background: #2563EB;
        border-radius: 4px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: #1d4ed8;
      }

      /* Animated gradient orbs */
      .orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
        opacity: 0.3;
        animation: orbFloat 8s ease-in-out infinite;
      }
      .orb-1 {
        width: 500px;
        height: 500px;
        background: radial-gradient(circle, #2563EB 0%, transparent 70%);
        top: -10%;
        left: -10%;
        animation-delay: 0s;
        animation-duration: 10s;
      }
      .orb-2 {
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, #1d4ed8 0%, transparent 70%);
        bottom: -5%;
        right: -5%;
        animation-delay: -3s;
        animation-duration: 12s;
      }
      .orb-3 {
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, #3b82f6 0%, transparent 70%);
        top: 40%;
        left: 50%;
        animation-delay: -5s;
        animation-duration: 14s;
        opacity: 0.15;
      }

      @keyframes orbFloat {
        0%, 100% {
          transform: translate(0, 0) scale(1);
        }
        25% {
          transform: translate(30px, -40px) scale(1.05);
        }
        50% {
          transform: translate(-20px, 20px) scale(0.95);
        }
        75% {
          transform: translate(40px, 30px) scale(1.02);
        }
      }

      /* Grid pattern background */
      .grid-pattern {
        background-image:
          linear-gradient(rgba(37, 99, 235, 0.03) 1px, transparent 1px),
          linear-gradient(90deg, rgba(37, 99, 235, 0.03) 1px, transparent 1px);
        background-size: 60px 60px;
      }

      /* Dot pattern background */
      .dot-pattern {
        background-image: radial-gradient(rgba(37, 99, 235, 0.12) 1px, transparent 1px);
        background-size: 30px 30px;
      }

      /* Submit button shine effect */
      .btn-shine {
        position: relative;
        overflow: hidden;
      }
      .btn-shine::after {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: linear-gradient(
          to right,
          transparent 0%,
          rgba(255, 255, 255, 0.1) 50%,
          transparent 100%
        );
        transform: rotate(30deg) translateX(-100%);
        transition: transform 0.6s ease;
      }
      .btn-shine:hover::after {
        transform: rotate(30deg) translateX(100%);
      }

      /* Dynamic Hover Grow effect */
      .hover-grow {
        transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.4s ease, border-color 0.4s ease;
      }
      .hover-grow:hover {
        transform: translateY(-6px) scale(1.02);
        box-shadow: 0 20px 40px -10px rgba(37, 99, 235, 0.2);
        border-color: rgba(37, 99, 235, 0.3);
      }

      /* Entrance Animations */
      @keyframes fadeInUp {
        from {
          opacity: 0;
          transform: translateY(24px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .animate-fade-in-up {
        animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      }

      /* Hover dynamic scaling for text/logos */
      .logo-pulse:hover {
        animation: logoPulse 1s ease-in-out infinite alternate;
      }
      @keyframes logoPulse {
        from { transform: scale(1); }
        to { transform: scale(1.08); }
      }

      /* Global scroll reveal */
      .reveal {
        opacity: 0;
        transform: translateY(32px) scale(0.98);
        transition: opacity 0.85s cubic-bezier(0.16, 1, 0.3, 1), transform 0.85s cubic-bezier(0.16, 1, 0.3, 1);
        will-change: transform, opacity;
      }
      .reveal.visible {
        opacity: 1;
        transform: translateY(0) scale(1);
      }

      /* Theme Toggle Icons */
      #theme-toggle .dark-icon { display: block; }
      #theme-toggle .light-icon { display: none; }
      :root.light #theme-toggle .dark-icon { display: none; }
      :root.light #theme-toggle .light-icon { display: block; }

      #theme-toggle-mobile .dark-icon-mobile { display: block; }
      #theme-toggle-mobile .light-icon-mobile { display: none; }
      :root.light #theme-toggle-mobile .dark-icon-mobile { display: none; }
      :root.light #theme-toggle-mobile .light-icon-mobile { display: block; }

      /* Light theme overrides for backgrounds, text, and borders */
      :root.light {
        color-scheme: light;
      }
      :root.light body {
        background-color: #F9FAFB !important;
        color: #0D0D0D !important;
      }
      :root.light nav#navbar {
        background-color: rgba(249, 250, 251, 0.8) !important;
        border-color: rgba(0, 0, 0, 0.08) !important;
      }
      :root.light nav#navbar .text-white {
        color: #0D0D0D !important;
      }
      :root.light nav#navbar .text-white\/70 {
        color: #4B5563 !important;
      }
      :root.light nav#navbar .text-white\/70:hover {
        color: #0D0D0D !important;
      }
      :root.light #mobile-menu {
        background-color: rgba(255, 255, 255, 0.95) !important;
        border-color: rgba(0, 0, 0, 0.08) !important;
      }
      :root.light #mobile-menu .text-white\/70 {
        color: #4B5563 !important;
      }
      :root.light #mobile-menu .text-white\/70:hover {
        color: #0D0D0D !important;
      }
      :root.light #mobile-menu .border-b {
        border-color: rgba(0, 0, 0, 0.08) !important;
      }

      /* Sections background overrides */
      :root.light .bg-\[\#1F1F1F\] {
        background-color: #FFFFFF !important;
      }
      :root.light .bg-\[\#0D0D0D\] {
        background-color: #F9FAFB !important;
      }
      :root.light .bg-\[\#0D0D0D\]\/60 {
        background-color: rgba(255, 255, 255, 0.6) !important;
      }
      
      /* Card overrides */
      :root.light .service-card,
      :root.light .glass-card,
      :root.light .value-card,
      :root.light .process-step bg-\[\#0D0D0D\]\/60,
      :root.light .process-line {
        background-color: #FFFFFF !important;
        border-color: rgba(0, 0, 0, 0.08) !important;
        color: #0D0D0D !important;
      }
      :root.light .service-card h3,
      :root.light .glass-card h2,
      :root.light .glass-card h3,
      :root.light .glass-card h4,
      :root.light .value-card h3,
      :root.light .stat-card p {
        color: #0D0D0D !important;
      }
      :root.light .service-card p,
      :root.light .glass-card p,
      :root.light .value-card p,
      :root.light .stat-card p.text-white\/50,
      :root.light .text-white\/40,
      :root.light .text-white\/45,
      :root.light .text-white\/50,
      :root.light .text-white\/55,
      :root.light .text-white\/60 {
        color: #4B5563 !important;
      }
      :root.light .border-white\/5,
      :root.light .border-white\/10 {
        border-color: rgba(0, 0, 0, 0.08) !important;
      }
      
      /* Footer light overrides */
      :root.light footer {
        background-color: #FFFFFF !important;
        border-color: rgba(0, 0, 0, 0.08) !important;
      }
      :root.light footer .border-b,
      :root.light footer .border-t {
        border-color: rgba(0, 0, 0, 0.08) !important;
      }
      :root.light footer span,
      :root.light footer a {
        color: #4B5563 !important;
      }
      :root.light footer a:hover {
        color: #2563EB !important;
      }

      /* Hero section dynamic tweaks */
      :root.light .hero-desc span.text-white\/70 {
        color: #1F1F1F !important;
      }
      :root.light .hero-desc span.text-white\/30 {
        color: #D1D5DB !important;
      }
      :root.light .hero-subtitle {
        color: #1F1F1F !important;
      }
      :root.light .orb {
        opacity: 0.12 !important;
      }

      /* Timeline tweak */
      :root.light .timeline-dot {
        background-color: #FFFFFF !important;
      }
      :root.light .process-step h3 {
        color: #0D0D0D !important;
      }
      
      /* Input overrides for forms */
      :root.light input,
      :root.light textarea,
      :root.light select {
        background-color: #FFFFFF !important;
        border-color: rgba(0, 0, 0, 0.12) !important;
        color: #0D0D0D !important;
      }
      :root.light input::placeholder,
      :root.light textarea::placeholder {
        color: #9CA3AF !important;
      }
      :root.light label {
        color: #4B5563 !important;
      }
      
      /* Fix for logo color */
      :root.light svg path[fill="currentColor"] {
        fill: #0D0D0D !important;
      }
      :root.light svg text tspan[fill="#FFFFFF"] {
        fill: #0D0D0D !important;
      }

      /* Headings and generic texts with hardcoded white color overrides */
      :root.light h1,
      :root.light h2,
      :root.light h3,
      :root.light h4,
      :root.light h5,
      :root.light h6,
      :root.light .text-white:not(a):not(button):not(.btn-shine):not(.timeline-dot) {
        color: #0D0D0D !important;
      }
      :root.light p,
      :root.light .text-white\/50,
      :root.light .text-white\/60,
      :root.light .text-white\/80,
      :root.light .text-white\/45,
      :root.light .text-white\/55 {
        color: #4B5563 !important;
      }
      
      /* Special styling tweaks for timeline dots in light theme */
      :root.light .timeline-dot span {
        color: #2563EB !important;
      }
    </style>
  </head>
  <body class="bg-[#0D0D0D] text-white overflow-x-hidden">
    <!-- ===================== NAVBAR ===================== -->
    <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 bg-[#0D0D0D]/80 backdrop-blur-lg border-b border-white/5">
      <div class="mx-auto max-w-6xl px-6 py-4 flex items-center justify-between">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 group">
          <svg width="45" height="32" viewBox="0 0 160 120" class="transition-transform group-hover:scale-110 duration-300">
            <!-- V (currentColor) -->
            <path d="M 10 15 L 25 15 L 48 80 L 71 15 L 86 15 L 55 105 L 41 105 Z" fill="currentColor" />
            <!-- W (Blue #2563EB) -->
            <path d="M 56 15 L 71 15 L 83 60 L 95 15 L 110 15 L 122 60 L 134 15 L 149 15 L 130 105 L 115 105 L 100 50 L 85 105 L 70 105 Z" fill="#2563EB" />
          </svg>
          <span class="text-white font-bold text-lg tracking-wider hidden sm:block">VISION <span class="text-[#2563EB]">WEB</span></span>
        </a>

        <!-- Desktop Navigation -->
        <div class="hidden md:flex items-center gap-8">
          <a href="/servicios" class="text-sm text-white/70 hover:text-white transition-colors duration-300 relative group">
            Servicios
            <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-[#2563EB] transition-all duration-300 group-hover:w-full"></span>
          </a>
          <a href="/proyectos" class="text-sm text-white/70 hover:text-white transition-colors duration-300 relative group">
            Proyectos
            <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-[#2563EB] transition-all duration-300 group-hover:w-full"></span>
          </a>
          <a href="/nosotros" class="text-sm text-white/70 hover:text-white transition-colors duration-300 relative group">
            Nosotros
            <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-[#2563EB] transition-all duration-300 group-hover:w-full"></span>
          </a>
          <!-- Theme Toggle Button -->
          <button id="theme-toggle" class="p-2.5 rounded-lg text-white/70 hover:text-white hover:bg-white/5 transition-all mr-2" aria-label="Toggle Theme">
            <i data-lucide="sun" class="w-5 h-5 dark-icon"></i>
            <i data-lucide="moon" class="w-5 h-5 light-icon"></i>
          </button>
          
          <a href="/contacto" class="bg-[#2563EB] hover:bg-blue-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-all duration-300 hover:shadow-lg hover:shadow-blue-500/25">
            Contacto
          </a>
        </div>

        <!-- Mobile Hamburger -->
        <button id="mobile-menu-toggle" class="md:hidden text-white/70 hover:text-white transition-colors">
          <i data-lucide="menu" class="w-6 h-6"></i>
        </button>
      </div>

      <!-- Mobile Menu -->
      <div id="mobile-menu" class="hidden md:hidden bg-[#1F1F1F]/95 backdrop-blur-xl border-t border-white/5">
        <div class="px-6 py-6 flex flex-col gap-4">
          <a href="/servicios" class="text-white/70 hover:text-white transition-colors py-2 border-b border-white/5">Servicios</a>
          <a href="/proyectos" class="text-white/70 hover:text-white transition-colors py-2 border-b border-white/5">Proyectos</a>
          <a href="/nosotros" class="text-white/70 hover:text-white transition-colors py-2 border-b border-white/5">Nosotros</a>
          <a href="/contacto" class="bg-[#2563EB] hover:bg-blue-700 text-white text-center font-semibold px-5 py-3 rounded-lg transition-all duration-300 mt-2">Contacto</a>
          
          <!-- Mobile Theme Toggle -->
          <div class="flex items-center justify-between py-2 border-b border-white/5 mt-2">
            <span class="text-sm text-white/70">Cambiar Tema</span>
            <button id="theme-toggle-mobile" class="p-2 rounded-lg text-white/70 hover:text-white hover:bg-white/5 transition-all" aria-label="Toggle Theme">
              <i data-lucide="sun" class="w-5 h-5 dark-icon-mobile"></i>
              <i data-lucide="moon" class="w-5 h-5 light-icon-mobile"></i>
            </button>
          </div>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="min-h-screen pt-20">
      <slot />
    </main>

    <!-- ===================== FOOTER ===================== -->
    <footer class="bg-[#0D0D0D] border-t border-white/10">
      <!-- Values Strip -->
      <div class="border-b border-white/10">
        <div class="mx-auto max-w-6xl px-6 py-6 grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
          <div class="flex flex-col items-center gap-2">
            <i data-lucide="palette" class="w-5 h-5 text-[#2563EB]"></i>
            <span class="text-xs font-semibold text-white/70 uppercase tracking-wider">Diseño que impacta</span>
          </div>
          <div class="flex flex-col items-center gap-2">
            <i data-lucide="code-2" class="w-5 h-5 text-[#2563EB]"></i>
            <span class="text-xs font-semibold text-white/70 uppercase tracking-wider">Tecnología que funciona</span>
          </div>
          <div class="flex flex-col items-center gap-2">
            <i data-lucide="trending-up" class="w-5 h-5 text-[#2563EB]"></i>
            <span class="text-xs font-semibold text-white/70 uppercase tracking-wider">Resultados que crecen</span>
          </div>
          <div class="flex flex-col items-center gap-2">
            <i data-lucide="users" class="w-5 h-5 text-[#2563EB]"></i>
            <span class="text-xs font-semibold text-white/70 uppercase tracking-wider">Acompañamiento real</span>
          </div>
        </div>
      </div>
      <!-- Copyright -->
      <div class="mx-auto max-w-6xl px-6 py-6 flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-2">
          <svg width="32" height="25" viewBox="0 0 160 120">
            <!-- V (currentColor) -->
            <path d="M 10 15 L 25 15 L 48 80 L 71 15 L 86 15 L 55 105 L 41 105 Z" fill="currentColor" />
            <!-- W (Blue #2563EB) -->
            <path d="M 56 15 L 71 15 L 83 60 L 95 15 L 110 15 L 122 60 L 134 15 L 149 15 L 130 105 L 115 105 L 100 50 L 85 105 L 70 105 Z" fill="#2563EB" />
          </svg>
          <span class="text-sm text-white/50">© 2026 Vision Web. Todos los derechos reservados.</span>
        </div>
        <div class="flex gap-4">
          <a href="https://www.instagram.com/visionweb.co" target="_blank" class="text-white/40 hover:text-[#2563EB] transition-colors"><i data-lucide="instagram" class="w-4 h-4"></i></a>
          <a href="#" class="text-white/40 hover:text-[#2563EB] transition-colors"><i data-lucide="linkedin" class="w-4 h-4"></i></a>
          <a href="mailto:edwin.camilo2004@gmail.com" class="text-white/40 hover:text-[#2563EB] transition-colors"><i data-lucide="mail" class="w-4 h-4"></i></a>
        </div>
      </div>
    </footer>

    <!-- ==================== SCRIPTS ==================== -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <script is:inline>
      // Mobile menu toggle & Theme toggle
      function initNavbar() {
        const mobileToggle = document.getElementById('mobile-menu-toggle');
        const mobileMenu = document.getElementById('mobile-menu');
        if (mobileToggle && mobileMenu) {
          mobileToggle.addEventListener('click', () => {
            mobileMenu.classList.toggle('hidden');
          });
        }
        
        // Initialize theme buttons listeners
        const toggleBtn = document.getElementById('theme-toggle');
        const toggleBtnMobile = document.getElementById('theme-toggle-mobile');
        
        const handleToggle = () => {
          const isLight = document.documentElement.classList.toggle('light');
          localStorage.setItem('theme', isLight ? 'light' : 'dark');
        };
        
        if (toggleBtn) {
          toggleBtn.removeEventListener('click', handleToggle);
          toggleBtn.addEventListener('click', handleToggle);
        }
        if (toggleBtnMobile) {
          toggleBtnMobile.removeEventListener('click', handleToggle);
          toggleBtnMobile.addEventListener('click', handleToggle);
        }

        if (window.lucide) {
          window.lucide.createIcons();
        }
      }

      // Initialize on load and on page navigation (Astro View Transitions)
      initNavbar();
      document.addEventListener('astro:page-load', initNavbar);
    </script>
  </body>
</html>
