---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contacto | Vision Web" description="Contáctanos para transformar tu presencia digital. En Vision Web diseñamos páginas web que conectan tu negocio con más clientes.">
  <!-- ===================== PAGE HEADER ===================== -->
  <section class="hero-gradient py-20 md:py-28 relative overflow-hidden">
    <div class="absolute inset-0 dot-pattern opacity-30"></div>
    
    <div class="relative z-10 mx-auto max-w-6xl px-6 text-center animate-fade-in-up">
      <h1 class="text-4xl md:text-6xl font-black text-white tracking-tight mb-6">
        Hablemos de tu <span class="text-[#2563EB]">Proyecto</span>
      </h1>
      <p class="text-white/50 max-w-2xl mx-auto text-base md:text-lg">
        DM para proyectos 🚀 Transforma tu presencia digital con nosotros.
      </p>
    </div>
  </section>

  <!-- ===================== CONTACT CONTENT ===================== -->
  <section class="relative py-20 bg-[#0D0D0D]">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
        
        <!-- Left: Company Info (Instagram Application concept) -->
        <div class="lg:col-span-5 space-y-8 reveal">
          <div>
            <h2 class="text-2xl font-extrabold text-white mb-2">Información de Contacto</h2>
            <p class="text-white/45 text-sm">Medios directos para comunicarte con nosotros de forma rápida.</p>
          </div>

          <!-- Faux Instagram Profile Widget -->
          <div class="glass-card rounded-2xl p-6 border border-white/5 relative overflow-hidden animate-pulse-glow">
            {/* Instagram Header Bar */}
            <div class="flex items-center justify-between pb-4 border-b border-white/5 mb-4">
              <div class="flex items-center gap-2">
                <i data-lucide="chevron-left" class="w-5 h-5 text-white/60"></i>
                <span class="font-bold text-sm text-white tracking-wide">visionwebs.co</span>
              </div>
              <div class="flex items-center gap-3">
                <i data-lucide="bell" class="w-5 h-5 text-white"></i>
                <i data-lucide="more-horizontal" class="w-5 h-5 text-white"></i>
              </div>
            </div>

            <div class="flex items-center justify-between mb-6">
              <div class="flex items-center gap-4">
                <div class="w-16 h-16 rounded-full bg-[#1F1F1F] border border-[#2563EB] flex items-center justify-center p-2.5">
                  <svg viewBox="0 0 160 120" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
                    <!-- V (currentColor) -->
                    <path d="M 10 15 L 25 15 L 48 80 L 71 15 L 86 15 L 55 105 L 41 105 Z" fill="currentColor" />
                    <!-- W (Blue #2563EB) -->
                    <path d="M 56 15 L 71 15 L 83 60 L 95 15 L 110 15 L 122 60 L 134 15 L 149 15 L 130 105 L 115 105 L 100 50 L 85 105 L 70 105 Z" fill="#2563EB" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-bold text-white leading-tight">Visionweb | CG</h3>
                  <p class="text-[11px] text-[#2563EB] font-semibold">Diseñador web</p>
                </div>
              </div>
              <a href="https://www.instagram.com/visionwebs.co" target="_blank" class="px-4 py-1.5 bg-[#2563EB] hover:bg-blue-700 text-white font-semibold text-xs rounded-lg transition-colors">
                Seguir
              </a>
            </div>

            <div class="grid grid-cols-3 gap-4 text-center border-y border-white/5 py-4 mb-6">
              <div>
                <p class="text-lg font-bold text-white">2</p>
                <p class="text-[10px] text-white/40 uppercase">Publicaciones</p>
              </div>
              <div>
                <p class="text-lg font-bold text-white">61</p>
                <p class="text-[10px] text-white/40 uppercase">Seguidores</p>
              </div>
              <div>
                <p class="text-lg font-bold text-white">384</p>
                <p class="text-[10px] text-white/40 uppercase">Seguidos</p>
              </div>
            </div>

            <div class="space-y-2 text-xs text-white/60 mb-6">
              <p class="text-white/80">Creamos páginas web que conectan tu negocio con más clientes.</p>
              <p>Sitios rápidos y optimizados 💻</p>
              <p>Diseño | Desarrollo | Estrategia</p>
              <p>Comienza tu proyecto 🚀</p>
              <p class="flex items-center gap-1.5 text-[#2563EB] font-medium pt-2">
                <i data-lucide="link" class="w-3.5 h-3.5"></i>
                <a href="https://wa.me/573052311490" target="_blank" class="hover:underline">WhatsApp</a>
              </p>
            </div>

            <div class="flex gap-2">
              <a href="mailto:edwin.camilo2004@gmail.com" class="flex-1 py-2 bg-white/5 hover:bg-white/10 text-white font-bold text-xs rounded-lg border border-white/10 text-center transition-colors">
                Enviar Correo
              </a>
              <a href="https://wa.me/573052311490" target="_blank" class="flex-1 py-2 bg-[#2563EB] hover:bg-blue-700 text-white font-bold text-xs rounded-lg text-center transition-colors">
                Chat WhatsApp
              </a>
            </div>
          </div>
        </div>

        <!-- Right: Contact Form -->
        <div class="lg:col-span-7 reveal" style="transition-delay: 0.1s;">
          <div class="glass-card rounded-3xl p-8 border border-white/5">
            <h3 class="text-xl font-bold text-white mb-2">Enviar Mensaje</h3>
            <p class="text-white/45 text-xs mb-6">Completa este formulario y te responderemos en menos de 24 horas.</p>

            <form action="https://formspree.io/f/xykaeove" method="POST" class="space-y-6">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div class="space-y-2">
                  <label for="name" class="text-xs font-semibold text-white/60 uppercase tracking-wider block">Nombre Completo</label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    placeholder="Ej. John Doe"
                    class="w-full bg-[#0D0D0D]/60 border border-white/10 rounded-xl px-4 py-3.5 text-sm text-white placeholder-white/20 focus:border-[#2563EB] outline-none transition-all input-glow"
                  />
                </div>
                <div class="space-y-2">
                  <label for="email" class="text-xs font-semibold text-white/60 uppercase tracking-wider block">Correo Electrónico</label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    placeholder="john@example.com"
                    class="w-full bg-[#0D0D0D]/60 border border-white/10 rounded-xl px-4 py-3.5 text-sm text-white placeholder-white/20 focus:border-[#2563EB] outline-none transition-all input-glow"
                  />
                </div>
              </div>

              <div class="space-y-2">
                <label for="subject" class="text-xs font-semibold text-white/60 uppercase tracking-wider block">Asunto</label>
                <input
                  type="text"
                  id="subject"
                  name="subject"
                  required
                  placeholder="Ej. Propuesta de Proyecto / Cotización"
                  class="w-full bg-[#0D0D0D]/60 border border-white/10 rounded-xl px-4 py-3.5 text-sm text-white placeholder-white/20 focus:border-[#2563EB] outline-none transition-all input-glow"
                />
              </div>

              <div class="space-y-2">
                <label for="message" class="text-xs font-semibold text-white/60 uppercase tracking-wider block">Mensaje</label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  required
                  placeholder="Escribe detalladamente tu consulta aquí..."
                  class="w-full bg-[#0D0D0D]/60 border border-white/10 rounded-xl px-4 py-3.5 text-sm text-white placeholder-white/20 focus:border-[#2563EB] outline-none transition-all input-glow resize-none"
                ></textarea>
              </div>

              <button
                type="submit"
                class="w-full py-4 bg-[#2563EB] hover:bg-blue-700 text-white font-bold rounded-xl transition-all duration-300 shadow-lg shadow-blue-500/20 text-sm block btn-shine"
              >
                Enviar Mensaje Profesional
              </button>
            </form>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===================== WHY CHOOSE US ===================== -->
  <section class="relative py-20 bg-[#1F1F1F]">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 text-center reveal">
        <!-- Card 1 -->
        <div class="bg-[#0D0D0D] border border-white/5 rounded-2xl p-6 hover:border-[#2563EB]/35 transition-colors">
          <div class="w-10 h-10 rounded-lg bg-[#2563EB]/15 flex items-center justify-center mx-auto mb-4">
            <i data-lucide="palette" class="w-5 h-5 text-[#2563EB]"></i>
          </div>
          <h4 class="font-bold text-white text-sm mb-1">Diseño que impacta</h4>
          <p class="text-white/40 text-[11px] leading-relaxed">Visuales profesionales que destacan frente a tus competidores.</p>
        </div>

        <!-- Card 2 -->
        <div class="bg-[#0D0D0D] border border-white/5 rounded-2xl p-6 hover:border-[#2563EB]/35 transition-colors">
          <div class="w-10 h-10 rounded-lg bg-[#2563EB]/15 flex items-center justify-center mx-auto mb-4">
            <i data-lucide="code-2" class="w-5 h-5 text-[#2563EB]"></i>
          </div>
          <h4 class="font-bold text-white text-sm mb-1">Tecnología robusta</h4>
          <p class="text-white/40 text-[11px] leading-relaxed">Sitios dinámicos en React optimizados para la máxima velocidad.</p>
        </div>

        <!-- Card 3 -->
        <div class="bg-[#0D0D0D] border border-white/5 rounded-2xl p-6 hover:border-[#2563EB]/35 transition-colors">
          <div class="w-10 h-10 rounded-lg bg-[#2563EB]/15 flex items-center justify-center mx-auto mb-4">
            <i data-lucide="trending-up" class="w-5 h-5 text-[#2563EB]"></i>
          </div>
          <h4 class="font-bold text-white text-sm mb-1">Resultados tangibles</h4>
          <p class="text-white/40 text-[11px] leading-relaxed">Diseñamos pensando en la atracción y conversión de clientes.</p>
        </div>

        <!-- Card 4 -->
        <div class="bg-[#0D0D0D] border border-white/5 rounded-2xl p-6 hover:border-[#2563EB]/35 transition-colors">
          <div class="w-10 h-10 rounded-lg bg-[#2563EB]/15 flex items-center justify-center mx-auto mb-4">
            <i data-lucide="users" class="w-5 h-5 text-[#2563EB]"></i>
          </div>
          <h4 class="font-bold text-white text-sm mb-1">Acompañamiento Real</h4>
          <p class="text-white/40 text-[11px] leading-relaxed">Soporte y consultoría continua en cada fase de tu camino digital.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Header styling */
  .hero-gradient {
    background: linear-gradient(135deg, #0D0D0D 0%, #1F1F1F 40%, #0D0D0D 70%, #0a1628 100%);
    position: relative;
    overflow: hidden;
  }
  .hero-gradient::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle at 30% 40%, rgba(37, 99, 235, 0.08) 0%, transparent 50%),
                radial-gradient(circle at 70% 60%, rgba(37, 99, 235, 0.05) 0%, transparent 50%);
    animation: subtle-pulse 8s ease-in-out infinite alternate;
  }
  @keyframes subtle-pulse {
    0% { opacity: 0.5; transform: scale(1); }
    100% { opacity: 1; transform: scale(1.05); }
  }

  /* Pulse Glow widget */
  @keyframes pulseGlow {
    0%, 100% { box-shadow: 0 0 20px rgba(37, 99, 235, 0.1); }
    50% { box-shadow: 0 0 35px rgba(37, 99, 235, 0.25); }
  }
  .animate-pulse-glow {
    animation: pulseGlow 3s ease-in-out infinite;
  }

  /* Glassmorphism */
  .glass-card {
    background: rgba(31, 31, 31, 0.6);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  /* Focus Glow */
  .input-glow:focus {
    box-shadow: 0 0 0 2px rgba(37, 99, 235, 0.4), 0 0 20px rgba(37, 99, 235, 0.15);
  }

  /* Fade-in */
  .animate-fade-in-up {
    animation: fadeInUp 0.8s ease-out forwards;
  }
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

</style>

<script is:inline>
  function initReveal() {
    const reveals = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.1 });
    
    reveals.forEach(el => observer.observe(el));
  }

  // Pre-fill form fields from query parameters (for custom quotes)
  function fillFormFromQuery() {
    const params = new URLSearchParams(window.location.search);
    const subject = params.get('subject');
    const message = params.get('message');
    if (subject) {
      const subjectInput = document.getElementById('subject');
      if (subjectInput) subjectInput.value = subject;
    }
    if (message) {
      const messageInput = document.getElementById('message');
      if (messageInput) messageInput.value = message;
    }
  }

  initReveal();
  fillFormFromQuery();
  document.addEventListener('astro:page-load', () => {
    initReveal();
    fillFormFromQuery();
  });
</script>
